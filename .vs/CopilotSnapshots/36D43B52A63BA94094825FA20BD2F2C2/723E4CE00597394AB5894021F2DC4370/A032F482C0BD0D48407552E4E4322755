@login_required
def conciliation_view(request: HttpRequest):
    """Main conciliation screen."""
    assert isinstance(request, HttpRequest)

    saint_cfg = getattr(settings, 'SAINT_DB', {})
    vendors = []
    system_totals = None

    # Build SAINT connection
    conn = None
    if pyodbc:
        try:
            if saint_cfg.get('DSN'):
                conn_str = f"DSN={saint_cfg['DSN']};"\
                           f"UID={saint_cfg.get('USER','')};PWD={saint_cfg.get('PASSWORD','')};"
            else:
                parts = []
                if saint_cfg.get('DRIVER'):
                    parts.append(f"DRIVER={saint_cfg['DRIVER']}")
                if saint_cfg.get('SERVER'):
                    parts.append(f"SERVER={saint_cfg['SERVER']}")
                if saint_cfg.get('DATABASE'):
                    parts.append(f"DATABASE={saint_cfg['DATABASE']}")
                if saint_cfg.get('USER'):
                    parts.append(f"UID={saint_cfg['USER']}")
                if saint_cfg.get('PASSWORD'):
                    parts.append(f"PWD={saint_cfg['PASSWORD']}")
                if saint_cfg.get('TRUSTED_CONNECTION'):
                    parts.append(f"Trusted_Connection={saint_cfg['TRUSTED_CONNECTION']}")
                conn_str = ';'.join(parts)
            if conn_str:
                conn = pyodbc.connect(conn_str, timeout=saint_cfg.get('TIMEOUT', 30))
                conn.autocommit = True
        except Exception as ex:  # pragma: no cover
            messages.error(request, f"Could not connect to SAINT database: {ex}")
            conn = None
    else:
        messages.warning(request, 'pyodbc is not installed. System totals cannot be queried.')

    # Load vendors
    if conn:
        try:
            with conn.cursor() as cur:
                cur.execute("""
                    SELECT CodVend, Descrip
                    FROM EnterpriseAdmin_AMC.dbo.SAVEND WITH (NOLOCK)
                    WHERE Activo = 1
                    ORDER BY Descrip
                """)
                vendors = [{'CodVend': r[0], 'Descrip': r[1]} for r in cur.fetchall()]
        except Exception as ex:  # pragma: no cover
            messages.error(request, f"Error loading vendors: {ex}")

    selected_vendor = request.POST.get('CodVend') if request.method == 'POST' else ''
    fecha_ini = request.POST.get('FechaIni') if request.method == 'POST' else ''
    fecha_fin = request.POST.get('FechaFin') if request.method == 'POST' else ''

    # Run main SQL when form submitted
    if request.method == 'POST' and conn and selected_vendor and fecha_ini and fecha_fin:
        try:
            params = {
                'FECHAINI': fecha_ini,
                'FECHAFIN': fecha_fin,
                'CODESTA': '',
                'CODZONA': '',
                'CODVEND': selected_vendor,
                'CODCLIE': '',
                'CODOPER': '',
                'CODUSUA': '',
                'CODUBIC': '',
            }

            sql = """
            SELECT R.CODSUCU,
                   SUM(R.TOTEFECTIVO) AS TOTEFECTIVO,
                   SUM(R.TOTGIROS) AS TOTGIROS,
                   SUM(R.TOTCHEQUE) AS TOTCHEQUE,
                   SUM(R.TOTTARJETA) AS TOTTARJETA,
                   SUM(R.TOTADELANTOS) AS TOTADELANTOS,
                   SUM(R.TOTRETIMP) AS TOTRETIMP
            FROM (
                SELECT F.CODSUCU, F.CODESTA, CONVERT(VARCHAR,F.FECHAT,112) AS FECHAT,
                       SUM(F.CancelE) AS TOTEFECTIVO,
                       SUM(F.CancelG) AS TOTGIROS,
                       SUM(F.CancelC) AS TOTCHEQUE,
                       SUM(F.CancelT) AS TOTTARJETA,
                       SUM(F.CancelA) AS TOTADELANTOS,
                       SUM(F.CancelI) AS TOTRETIMP
                FROM [dbo].VW_ADM_FACTURAS AS F WITH (NOLOCK)
                     INNER JOIN SACLIE CL ON (CL.CODCLIE=F.CODCLIE)
                                         AND (SUBSTRING(ISNULL(CL.CODZONA,''),1,LEN(?+''))=?+'')
                WHERE (F.FECHAE>=?) AND (F.FECHAE<=?)
                  AND (SUBSTRING(ISNULL(F.CODESTA,''),1,LEN(?+''))=?+'')
                  AND (SUBSTRING(ISNULL(F.CODVEND,''),1,LEN(?+''))=?+'')
                  AND (SUBSTRING(ISNULL(F.CODCLIE,''),1,LEN(?+''))=?+'')
                  AND (SUBSTRING(ISNULL(F.CODOPER,''),1,LEN(?+''))=?+'')
                  AND (SUBSTRING(ISNULL(F.CODUSUA,''),1,LEN(?+''))=?+'')
                  AND (SUBSTRING(ISNULL(F.CODUBIC,''),1,LEN(?+''))=?+'')
                GROUP BY F.CODSUCU, F.CODESTA, CONVERT(VARCHAR,F.FECHAT,112)
                UNION ALL
                SELECT C.CODSUCU, C.CODESTA, CONVERT(VARCHAR,C.FECHAT,112) AS FECHAT,
                       0 AS TOTEFECTIVO,
                       SUM(CASE WHEN C.TIPOCXC='50' THEN 0 WHEN C.TIPOCXC='25' THEN 0 ELSE C.CANCELG END) AS TOTGIROS,
                       SUM(CASE WHEN C.TIPOCXC='50' THEN 0 WHEN C.TIPOCXC='25' THEN 0 ELSE C.CANCELC END) AS TOTCHEQUE,
                       SUM(CASE WHEN C.TIPOCXC='50' THEN 0 WHEN C.TIPOCXC='25' THEN 0 ELSE C.CANCELT END) AS TOTTARJETA,
                       SUM(CASE WHEN C.TIPOCXC='50' THEN 0 WHEN C.TIPOCXC='25' THEN 0 ELSE C.CANCELA END) AS TOTADELANTOS,
                       SUM(CASE WHEN C.TIPOCXC='50' THEN 0 WHEN C.TIPOCXC='25' THEN 0 ELSE C.CANCELI END) AS TOTRETIMP
                FROM [dbo].[SAACXC] AS C WITH (NOLOCK)
                     INNER JOIN SACLIE CL ON (CL.CODCLIE=C.CODCLie)
                                         AND (SUBSTRING(ISNULL(CL.CODZONA,''),1,LEN(?+''))=?+'')
                WHERE ((SUBSTRING(C.TIPOCXC,1,1) IN ('3','4','5')) OR (C.TIPOCXC='25'))
                  AND (C.FROMTRAN=1)
                  AND (C.FECHAE>=?) AND (C.FECHAE<=?)
                  AND (SUBSTRING(ISNULL(C.CODESTA,''),1,LEN(?+''))=?+'')
                  AND (SUBSTRING(ISNULL(C.CODVEND,''),1,LEN(?+''))=?+'')
                  AND (SUBSTRING(ISNULL(C.CODCLIE,''),1,LEN(?+''))=?+'')
                  AND (SUBSTRING(ISNULL(C.CODOPER,''),1,LEN(?+''))=?+'')
                  AND (SUBSTRING(ISNULL(C.CODUSUA,''),1,LEN(?+''))=?+'')
                GROUP BY C.CODSUCU, C.CODESTA, CONVERT(VARCHAR,C.FECHAT,112)
            ) R
            GROUP BY R.CODSUCU
            """

            args = [
                params['CODZONA'], params['CODZONA'],
                params['FECHAINI'], params['FECHAFIN'],
                params['CODESTA'], params['CODESTA'],
                params['CODVEND'], params['CODVEND'],
                params['CODCLIE'], params['CODCLIE'],
                params['CODOPER'], params['CODOPER'],
                params['CODUSUA'], params['CODUSUA'],
                params['CODUBIC'], params['CODUBIC'],
                params['CODZONA'], params['CODZONA'],
                params['FECHAINI'], params['FECHAFIN'],
                params['CODESTA'], params['CODESTA'],
                params['CODVEND'], params['CODVEND'],
                params['CODCLIE'], params['CODCLIE'],
                params['CODOPER'], params['CODOPER'],
                params['CODUSUA'], params['CODUSUA'],
            ]

            with conn.cursor() as cur:
                cur.execute(sql, args)
                row = cur.fetchone()
                if row:
                    system_totals = {
                        'TOTEFECTIVO': Decimal(getattr(row, 'TOTEFECTIVO', row[1] or 0)),
                        'TOTCHEQUE': Decimal(getattr(row, 'TOTCHEQUE', row[3] or 0)),
                        'TOTTARJETA': Decimal(getattr(row, 'TOTTARJETA', row[4] or 0)),
                        'TOTGIROS': Decimal(getattr(row, 'TOTGIROS', row[2] or 0)),
                        'TOTADELANTOS': Decimal(getattr(row, 'TOTADELANTOS', row[5] or 0)),
                        'TOTRETIMP': Decimal(getattr(row, 'TOTRETIMP', row[6] or 0)),
                    }
                else:
                    system_totals = {
                        'TOTEFECTIVO': Decimal(0),
                        'TOTCHEQUE': Decimal(0),
                        'TOTTARJETA': Decimal(0),
                        'TOTGIROS': Decimal(0),
                        'TOTADELANTOS': Decimal(0),
                        'TOTRETIMP': Decimal(0),
                    }
        except Exception as ex:  # pragma: no cover
            messages.error(request, f"Error running summary query: {ex}")

    context = {
        'title': 'Cashier Conciliation',
        'vendors': vendors,
        'selected_vendor': selected_vendor,
        'fecha_ini': fecha_ini,
        'fecha_fin': fecha_fin,
        'system_totals': system_totals,
        'is_admin': request.user.is_superuser or request.user.is_staff,
    }
    return render(request, 'app/conciliation.html', context)


