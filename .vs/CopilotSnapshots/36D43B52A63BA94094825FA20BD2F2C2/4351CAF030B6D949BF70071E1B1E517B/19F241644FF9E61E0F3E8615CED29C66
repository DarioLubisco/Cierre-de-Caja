# Load .env variables (simple parser, no external dependency)
ENV_FILE = os.path.join(BASE_DIR, '.env')
if os.path.exists(ENV_FILE):
    try:
        with open(ENV_FILE, 'r', encoding='utf-8') as fh:
            for line in fh:
                line = line.strip()
                if not line or line.startswith('#'):
                    continue
                if '=' in line:
                    k, v = line.split('=', 1)
                    if k and v:
                        os.environ.setdefault(k.strip(), v.strip())
    except Exception:
        pass  # Silently ignore .env parsing issues

